{
  "name": "pixel-portfolio",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "biome lint .",
    "lint:biome": "biome lint .",
    "lint:biome:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "check:staged": "biome check --staged --write --no-errors-on-unmatched",
    "biome:ci": "biome ci .",
    "notion:sync": "node scripts/sync-notion.mjs",
    "verify": "tsc -b && biome ci ."
  },
  "dependencies": {
    "@radix-ui/react-collapsible": "^1.1.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-scroll-area": "^1.2.12",
    "@radix-ui/react-separator": "^1.1.10",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@tailwindcss/vite": "^4.3.1",
    "@xstate/react": "^6.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "lucide-react": "^1.21.0",
    "notion-client": "^7.10.0",
    "notion-types": "^7.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-notion-x": "^7.10.0",
    "simple-icons": "^16.24.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "xstate": "^5.32.1"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "~6.0.3",
    "vite": "^8.0.16",
    "vite-imagetools": "^10.0.1"
  }
}
